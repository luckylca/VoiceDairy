{
  "name": "voicedairy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:dev": "adb reverse tcp:8081 tcp:8081 && react-native run-android",
    "prepare:asr": "bash scripts/prepare-asr-assets.sh",
    "postinstall": "node scripts/patch-llama-rn-bridge.js",
    "start": "react-native start",
    "dev": "adb reverse tcp:8081 tcp:8081 && sh -c 'react-native start --reset-cache & METRO_PID=$!; sleep 5; adb shell am start -n com.voicedairy/.MainActivity; wait $METRO_PID'",
    "quick": "adb reverse tcp:8081 tcp:8081 && adb shell am start -n com.voicedairy/.MainActivity",
    "restart": "adb reverse tcp:8081 tcp:8081 && adb shell am force-stop com.voicedairy && adb shell am start -n com.voicedairy/.MainActivity",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "llama.rn": "0.12.6",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-fs": "2.20.0",
    "react-native-pager-view": "^6.3.4",
    "react-native-paper": "^5.12.5",
    "react-native-safe-area-context": "^4.10.9",
    "react-native-screens": "^3.34.0",
    "react-native-vector-icons": "^10.1.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/babel-preset": "0.74.0",
    "@react-native/metro-config": "0.74.0",
    "@types/react": "^18.2.79",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
